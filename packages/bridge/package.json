{
  "name": "@pot-sdk2/bridge",
  "version": "1.3.0",
  "description": "Cross-agent trust verification — The Bridge (v0.9)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "node --import tsx/esm tests/bridge.test.ts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "keywords": [
    "thoughtproof",
    "pot-sdk",
    "trust",
    "bridge",
    "cross-agent",
    "verification",
    "decay"
  ],
  "homepage": "https://thoughtproof.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThoughtProof/pot-sdk"
  }
}
